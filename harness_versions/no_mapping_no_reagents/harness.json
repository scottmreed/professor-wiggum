{
  "name": "no_mapping_no_reagents",
  "schema_version": "2.0",
  "description": "Example harness that skips atom mapping and missing reagent prediction. Useful for studying how the mechanism loop performs without these pre-loop LLM calls. All other steps (balance analysis, functional groups, pH, conditions) still run.",
  "tool_calling_mode": "forced",
  "few_shot_defaults": {
    "enabled": true,
    "max_examples": 4,
    "selection_strategy": "top_score"
  },
  "execution_note": "Modules execute in listed order within each phase. pre_loop_modules runs once before the loop; loop_module runs each iteration before post_step_modules; post_step_modules runs after each accepted mechanism step. Array position (step field) is the authoritative execution sequence.",
  "pre_loop_modules": [
    {
      "step": 1,
      "id": "balance_analysis",
      "label": "Check Atom Balance",
      "kind": "deterministic",
      "phase": "pre_loop",
      "enabled": true,
      "agent_class": "BalanceAgent",
      "tool_function": "analyse_balance",
      "step_name": "balance_analysis",
      "tool_name": "analyse_balance",
      "validator_skill": null,
      "inputs": [],
      "outputs": ["balance_analysis"],
      "movable": false,
      "removable": false,
      "config_gate": null,
      "prompt_call_name": null,
      "group_key": null,
      "description": "RDKit counts atoms on each side of the reaction. Reports whether starting materials and products are stoichiometrically balanced, and lists any deficit or surplus atoms. Runs once at the start.",
      "io_schema": {
        "inputs": ["starting_materials (SMILES[])", "products (SMILES[])"],
        "outputs": ["balanced (bool)", "deficit (object)", "surplus (object)"]
      }
    },
    {
      "step": 2,
      "id": "functional_groups",
      "label": "Identify Functional Groups",
      "kind": "deterministic",
      "phase": "pre_loop",
      "enabled": true,
      "agent_class": "FunctionalGroupsAgent",
      "tool_function": "fingerprint_functional_groups",
      "step_name": "functional_groups",
      "tool_name": "fingerprint_functional_groups",
      "validator_skill": null,
      "inputs": [],
      "outputs": ["functional_groups"],
      "movable": true,
      "removable": true,
      "config_gate": "functional_groups_enabled",
      "prompt_call_name": null,
      "group_key": null,
      "description": "SMARTS pattern matching identifies reactive functional groups and leaving groups.",
      "io_schema": {
        "inputs": ["starting_materials (SMILES[])", "products (SMILES[])"],
        "outputs": ["functional_groups (object: group -> count)", "leaving_groups (string[])"]
      }
    },
    {
      "step": 3,
      "id": "ph_recommendation",
      "label": "Recommend pH",
      "kind": "deterministic",
      "phase": "pre_loop",
      "enabled": true,
      "agent_class": "ConditionsAgent",
      "tool_function": "recommend_ph",
      "step_name": "ph_recommendation",
      "tool_name": "recommend_ph",
      "validator_skill": null,
      "inputs": [],
      "outputs": ["ph_recommendation"],
      "movable": false,
      "removable": false,
      "config_gate": null,
      "prompt_call_name": null,
      "group_key": "conditions_pair",
      "description": "Rule-based pH suggestion.",
      "io_schema": {
        "inputs": ["starting_materials (SMILES[])", "products (SMILES[])", "user_ph (optional)"],
        "outputs": ["recommended_ph (float)", "source (user/heuristic/dimorphite)"]
      }
    },
    {
      "step": 4,
      "id": "initial_conditions",
      "label": "Assess Reaction Conditions",
      "kind": "llm",
      "phase": "pre_loop",
      "enabled": true,
      "agent_class": "ConditionsAgent",
      "tool_function": "assess_initial_conditions",
      "step_name": "initial_conditions",
      "tool_name": "assess_initial_conditions",
      "validator_skill": null,
      "inputs": ["ph_recommendation"],
      "outputs": ["initial_conditions"],
      "movable": false,
      "removable": false,
      "config_gate": null,
      "prompt_call_name": "assess_initial_conditions",
      "group_key": "conditions_pair",
      "description": "LLM call that assesses pH environment and acid/base candidates.",
      "io_schema": {
        "inputs": ["starting_materials (SMILES[])", "products (SMILES[])", "ph (from pH recommendation or user)", "functional_groups (if enabled)"],
        "outputs": ["environment (acidic/basic/neutral)", "representative_ph", "ph_range", "acid_candidates (acidic only)", "base_candidates (basic only)", "warnings"]
      }
    },
    {
      "step": 5,
      "id": "missing_reagents",
      "label": "Predict Missing Reagents",
      "kind": "llm",
      "phase": "pre_loop",
      "enabled": false,
      "agent_class": "MissingReagentsAgent",
      "tool_function": "predict_missing_reagents",
      "step_name": "missing_reagents",
      "tool_name": "predict_missing_reagents",
      "validator_skill": null,
      "inputs": ["initial_conditions"],
      "outputs": ["missing_reagents"],
      "movable": true,
      "removable": true,
      "config_gate": "optional_llm_tools:predict_missing_reagents",
      "prompt_call_name": "predict_missing_reagents",
      "group_key": null,
      "description": "SKIPPED in this harness variant. Set enabled: true to restore.",
      "io_schema": {
        "inputs": ["starting_materials (SMILES[])", "products (SMILES[])", "conditions_guidance"],
        "outputs": ["missing_reactants (SMILES[])", "missing_products (SMILES[])", "verification"]
      }
    },
    {
      "step": 6,
      "id": "atom_mapping",
      "label": "Map Atoms Between Reactants/Products",
      "kind": "llm",
      "phase": "pre_loop",
      "enabled": false,
      "agent_class": "MappingAgent",
      "tool_function": "attempt_atom_mapping",
      "step_name": "atom_mapping",
      "tool_name": "attempt_atom_mapping",
      "validator_skill": null,
      "inputs": [],
      "outputs": ["atom_mapping"],
      "movable": true,
      "removable": true,
      "config_gate": "optional_llm_tools:attempt_atom_mapping",
      "prompt_call_name": "attempt_atom_mapping",
      "group_key": null,
      "description": "SKIPPED in this harness variant. Set enabled: true to restore.",
      "io_schema": {
        "inputs": ["starting_materials (SMILES[])", "products (SMILES[])", "functional_groups (if enabled)"],
        "outputs": ["mapped_atoms", "unmapped_atoms", "confidence", "reasoning"]
      }
    },
    {
      "step": 7,
      "id": "reaction_type_mapping",
      "label": "Map To Reaction Type",
      "kind": "llm",
      "phase": "pre_loop",
      "enabled": true,
      "agent_class": "ReactionTypeAgent",
      "tool_function": "select_reaction_type",
      "step_name": "reaction_type_mapping",
      "tool_name": "select_reaction_type",
      "validator_skill": null,
      "inputs": ["balance_analysis", "functional_groups", "ph_recommendation", "initial_conditions", "missing_reagents", "atom_mapping"],
      "outputs": ["reaction_type_mapping"],
      "movable": true,
      "removable": true,
      "config_gate": "reaction_template_policy:auto",
      "prompt_call_name": "select_reaction_type",
      "group_key": null,
      "description": "LLM call that maps the reaction to one mechanism taxonomy label.",
      "io_schema": {
        "inputs": ["starting_materials (SMILES[])", "products (SMILES[])", "balance_analysis", "functional_groups", "ph_recommendation", "initial_conditions"],
        "outputs": ["selected_label_exact (taxonomy label or no_match)", "selected_type_id", "confidence (0-1)", "rationale", "top_candidates"]
      }
    }
  ],
  "loop_module": {
    "id": "mechanism_step_proposal",
    "label": "Propose Mechanism Step",
    "kind": "llm",
    "phase": "loop",
    "agent_class": "IntermediateAgent",
    "tool_function": "propose_intermediates",
    "step_name": "mechanism_step_proposal",
    "prompt_call_name": "propose_mechanism_step",
    "max_candidates": 3,
    "max_retries_per_candidate": 3,
    "description": "Core LLM call executed each iteration of the mechanism loop.",
    "io_schema": {
      "inputs": ["current_state (SMILES[])", "previous_intermediates", "conditions_guidance", "reaction_type"],
      "outputs": ["candidates (ranked list of intermediate_smiles, resulting_state, reaction_smirks, electron_pushes, step_label)"]
    }
  },
  "post_step_modules": [
    {
      "step": 1,
      "id": "bond_electron_validation",
      "label": "Check Bond/Electron Conservation",
      "kind": "deterministic",
      "phase": "post_step",
      "enabled": true,
      "agent_class": "",
      "tool_function": "",
      "step_name": "bond_electron_validation",
      "tool_name": "",
      "validator_skill": "bond_electron_validation",
      "inputs": [],
      "outputs": ["bond_electron_validation"],
      "movable": false,
      "removable": true,
      "config_gate": null,
      "prompt_call_name": null,
      "group_key": "validators",
      "description": "Parses DBE metadata tags from the reaction SMIRKS and verifies bond-order and electron-count changes sum to zero.",
      "io_schema": {
        "inputs": ["reaction_smirks (with DBE metadata)"],
        "outputs": ["valid (bool)", "total_delta", "message"]
      }
    },
    {
      "step": 2,
      "id": "atom_balance_validation",
      "label": "Check Step Atom Balance",
      "kind": "deterministic",
      "phase": "post_step",
      "enabled": true,
      "agent_class": "",
      "tool_function": "",
      "step_name": "atom_balance_validation",
      "tool_name": "",
      "validator_skill": "atom_balance_validation",
      "inputs": [],
      "outputs": ["atom_balance_validation"],
      "movable": false,
      "removable": true,
      "config_gate": null,
      "prompt_call_name": null,
      "group_key": "validators",
      "description": "RDKit verifies that every atom in the current state appears in the resulting state.",
      "io_schema": {
        "inputs": ["current_state (SMILES[])", "resulting_state (SMILES[])"],
        "outputs": ["balanced (bool)", "deficit", "surplus"]
      }
    },
    {
      "step": 3,
      "id": "state_progress_validation",
      "label": "Check State Changed",
      "kind": "deterministic",
      "phase": "post_step",
      "enabled": true,
      "agent_class": "",
      "tool_function": "",
      "step_name": "state_progress_validation",
      "tool_name": "",
      "validator_skill": "state_progress_validation",
      "inputs": [],
      "outputs": ["state_progress_validation"],
      "movable": false,
      "removable": true,
      "config_gate": null,
      "prompt_call_name": null,
      "group_key": "validators",
      "description": "Checks that the resulting state differs from the current state.",
      "io_schema": {
        "inputs": ["current_state (SMILES[])", "resulting_state (SMILES[])"],
        "outputs": ["resulting_state_changed (bool)", "unchanged_starting_materials_detected (bool)"]
      }
    },
    {
      "step": 4,
      "id": "reflection",
      "label": "Collect Validation Warnings",
      "kind": "deterministic",
      "phase": "post_step",
      "enabled": true,
      "agent_class": "ReflectionAgent",
      "tool_function": "",
      "step_name": "reflection",
      "tool_name": "reflection_agent",
      "validator_skill": null,
      "inputs": [],
      "outputs": ["reflection"],
      "movable": false,
      "removable": true,
      "config_gate": null,
      "prompt_call_name": null,
      "group_key": null,
      "description": "Deterministic aggregation of validation warnings from the accepted mechanism step.",
      "io_schema": {
        "inputs": ["mechanism_step_output", "validation_result"],
        "outputs": ["warnings (string[])", "critique_signals"]
      }
    },
    {
      "step": 5,
      "id": "step_atom_mapping",
      "label": "Map Atoms for Step",
      "kind": "llm",
      "phase": "post_step",
      "enabled": true,
      "agent_class": "MappingAgent",
      "tool_function": "attempt_atom_mapping_for_step",
      "step_name": "step_atom_mapping",
      "tool_name": "attempt_atom_mapping_for_step",
      "validator_skill": null,
      "inputs": [],
      "outputs": ["step_atom_mapping"],
      "movable": true,
      "removable": true,
      "config_gate": "step_mapping_enabled",
      "prompt_call_name": "attempt_atom_mapping",
      "group_key": null,
      "description": "LLM atom mapping for the accepted mechanism step.",
      "io_schema": {
        "inputs": ["current_state (SMILES[])", "resulting_state (SMILES[])"],
        "outputs": ["compact_mapped_atoms", "unmapped_atoms"]
      }
    }
  ],
  "metadata": {
    "description": "Example harness for contributors: demonstrates how to skip pre-loop LLM steps. Missing reagent prediction and atom mapping are disabled (enabled: false). Compare leaderboard scores against 'default' to measure their contribution. See docs/harness_cookbook.md for full instructions.",
    "created_from": "default",
    "changelog": [
      {
        "version": 1,
        "date": "2026-03-04",
        "description": "Created as a contributor example: atom_mapping and missing_reagents disabled to show how to skip removable pre-loop steps."
      }
    ]
  }
}
