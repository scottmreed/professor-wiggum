# Required to use OpenAI models (gpt-4o, o3, etc.)
OPENAI_API_KEY=

# Required to use OpenRouter (provides access to Claude, Gemini, Llama, and others)
OPENROUTER_API_KEY=

# Required to use Google Gemini models directly
GOOGLE_API_KEY=
# GEMINI_API_KEY= is also accepted as an alternative to GOOGLE_API_KEY.

# At least one key must be set for any LLM call to succeed.
# Only the key for the provider you use is required — you do not need all three.
# Example: to run Claude models via OpenRouter, only OPENROUTER_API_KEY is needed.
