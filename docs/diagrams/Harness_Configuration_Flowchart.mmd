    style MissingReagents fill:#d1ecf1
    style AtomMapping fill:#d1ecf1
    style ReactionType fill:#d1ecf1
    style MechanismProposal fill:#cfe2ff
    style BondElectronValidation fill:#f8d7da
    style AtomBalanceValidation fill:#f8d7da
    style StateProgressValidation fill:#f8d7da
    style Reflection fill:#d1ecf1
    style StepAtomMapping fill:#d1ecf1
    style LoopBack fill:#f0f0f0